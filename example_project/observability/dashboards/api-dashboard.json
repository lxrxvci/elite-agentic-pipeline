{
  "dashboard": {
    "id": null,
    "title": "Elite API",
    "tags": ["elite", "api"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Request Rate",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(elite_request_duration_seconds_count[5m])",
            "legendFormat": "{{method}} {{path}}"
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
      },
      {
        "id": 2,
        "title": "p95 Latency",
        "type": "timeseries",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(elite_request_duration_seconds_bucket[5m]))",
            "legendFormat": "{{method}} {{path}}"
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
      },
      {
        "id": 3,
        "title": "Error Rate",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(elite_request_duration_seconds_count{status_code=~\"5..\"}[5m])",
            "legendFormat": "5xx errors"
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
      },
      {
        "id": 4,
        "title": "Business Events",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(elite_logins_total[5m])",
            "legendFormat": "logins"
          },
          {
            "expr": "rate(elite_time_entries_created_total[5m])",
            "legendFormat": "time entries"
          },
          {
            "expr": "rate(elite_invoices_created_total[5m])",
            "legendFormat": "invoices"
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
      }
    ],
    "time": { "from": "now-1h", "to": "now" },
    "schemaVersion": 36
  }
}
