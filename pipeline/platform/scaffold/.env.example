# Backend
ENV=development
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/elite_db
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Clerk OIDC/OAuth2 (production identity provider)
# Leave unset in development to use the dev-only JWT endpoint.
# CLERK_JWKS_URL=https://your-domain.clerk.accounts.dev/.well-known/jwks.json
# CLERK_AUDIENCE=your-clerk-audience
# CLERK_ISSUER=https://your-domain.clerk.accounts.dev

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Feature flags (comma-separated list of enabled flag keys)
# Used as fallback when Unleash is not configured.
ENABLED_FEATURES=time-capture.quick-entry,time-capture.live-timer
NEXT_PUBLIC_ENABLED_FEATURES=time-capture.quick-entry,time-capture.live-timer

# Unleash feature flag provider (optional)
# When UNLEASH_URL is set, the backend uses Unleash instead of ENABLED_FEATURES.
UNLEASH_URL=http://localhost:4242/api
UNLEASH_API_TOKEN=default:development.unleash-insecure-api-token
UNLEASH_APP_NAME=elite-backend

# Frontend Unleash proxy (optional)
NEXT_PUBLIC_UNLEASH_PROXY_URL=http://localhost:3000/api/unleash-proxy
NEXT_PUBLIC_UNLEASH_CLIENT_KEY=default:development.unleash-insecure-api-token
NEXT_PUBLIC_UNLEASH_APP_NAME=elite-frontend

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
LOG_LEVEL=info

# Security warning
# Do not use the default SECRET_KEY in production. Generate a strong random
# value and set ENV=production to disable the dev-only auth endpoint.
