{
  "dashboard": {
    "id": null,
    "title": "DORA Metrics",
    "tags": ["dora", "elite"],
    "timezone": "utc",
    "schemaVersion": 39,
    "refresh": "1h",
    "panels": [
      {
        "id": 1,
        "title": "Deployment Frequency (30d)",
        "type": "stat",
        "targets": [
          {
            "expr": "elite_deployments_total{window=\"30d\"}",
            "legendFormat": "Deployments"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "min": 0
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Median Lead Time",
        "type": "stat",
        "targets": [
          {
            "expr": "elite_lead_time_seconds{window=\"30d\"}",
            "legendFormat": "Lead Time"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 6, "y": 0}
      },
      {
        "id": 3,
        "title": "Change Failure Rate",
        "type": "stat",
        "targets": [
          {
            "expr": "elite_change_failure_rate{window=\"30d\"}",
            "legendFormat": "CFR"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "max": 1,
            "min": 0,
            "thresholds": {
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 0.05},
                {"color": "red", "value": 0.15}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 12, "y": 0}
      },
      {
        "id": 4,
        "title": "Median Recovery Time",
        "type": "stat",
        "targets": [
          {
            "expr": "elite_recovery_time_seconds{window=\"30d\"}",
            "legendFormat": "MTTR"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 18, "y": 0}
      }
    ]
  }
}
