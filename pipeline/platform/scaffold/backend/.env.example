ENV=development
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/elite_db
SECRET_KEY=change-me-in-production

# Comma-separated list of origins allowed to call the API. Must include the
# production frontend origin and any backend canary preview origins when canary
# API traffic is routed via the frontend edge middleware.
ALLOWED_ORIGINS=http://localhost:3000

# Redis is required for multi-process rate limiting and tenant quotas.
# Use Upstash Redis in production or the local Redis service from docker-compose.
REDIS_URL=redis://localhost:6379/0

# Observability (optional). When OTEL_EXPORTER_OTLP_ENDPOINT is set, metrics and
# traces are exported to Grafana Cloud/Honeycomb/Datadog instead of staying
# in-process.
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-us-east-1.grafana.net/otlp
# Add auth headers for hosted OTLP, e.g.:
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic%20base64encodedtoken
OTEL_SERVICE_NAME=elite-backend
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=development
LOG_LEVEL=info

# Clerk JWT verification (required in production when ENV=production).
CLERK_JWKS_URL=https://example.clerk.accounts.dev/.well-known/jwks.json
CLERK_AUDIENCE=
CLERK_ISSUER=https://example.clerk.accounts.dev

# Feature flags (optional). Fallback is the comma-separated ENABLED_FEATURES list.
ENABLED_FEATURES=
MANAGED_FEATURE_FLAGS_URL=
MANAGED_FEATURE_FLAGS_TOKEN=
UNLEASH_URL=
UNLEASH_API_TOKEN=
UNLEASH_APP_NAME=elite-backend

# Security warning
# Do not use the default SECRET_KEY in production. Generate a strong random
# value and set ENV=production to disable the dev-only auth endpoint.
