  "component": {
    "button": {
      "font": "{semantic.font.label}",
      "radius": "{semantic.radius.button}",
      "padding-x": "{global.spacing.6}",
      "padding-y": "{global.spacing.3}",
      "gap": "{global.spacing.2}",
      "primary": {
        "background": "{semantic.color.interactive-default}",
        "text": "{semantic.color.text-inverse}",
        "border": "transparent",
        "shadow": "none",
        "hover": {
          "background": "{semantic.color.interactive-hover}",
          "transform": "{semantic.motion.hover-lift}",
          "shadow": "{semantic.shadow.button}"
        },
        "active": {
          "background": "{semantic.color.interactive-active}"
        },
        "disabled": {
          "background": "{global.color.neutral-200}",
          "text": "{global.color.neutral-400}",
          "transform": "none"
        }
      },
      "secondary": {
        "background": "{semantic.color.interactive-subtle}",
        "text": "{semantic.color.interactive-default}",
        "border": "transparent",
        "hover": {
          "background": "{global.color.cobalt-200}"
        }
      },
      "outline": {
        "background": "transparent",
        "text": "{semantic.color.text-primary}",
        "border": "{semantic.color.border-strong}",
        "hover": {
          "background": "{semantic.color.background-subtle}"
        }
      },
      "ghost": {
        "background": "transparent",
        "text": "{semantic.color.text-secondary}",
        "border": "transparent",
        "hover": {
