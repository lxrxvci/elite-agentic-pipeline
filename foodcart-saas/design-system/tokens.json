          "text": "{semantic.color.text-primary}"
        }
      },
      "danger": {
        "background": "{global.color.danger-500}",
        "text": "{global.color.white}",
        "hover": {
          "background": "{global.color.danger-700}"
        }
      },
      "focus": {
        "ring": "{semantic.color.focus-ring}",
        "ringWidth": "2px",
        "ringOffset": "2px"
      }
    },
    "card": {
      "background": "{semantic.color.surface-default}",
      "border": "{semantic.color.border-default}",
      "radius": "{semantic.radius.card}",
      "shadow": "{semantic.shadow.card}",
      "padding": "{global.spacing.6}",
      "hover": {
        "shadow": "{semantic.shadow.elevated}",
        "transform": "{semantic.motion.hover-lift}"
      }
    },
