    "previewFrame": {
      "toolbarHeight": "3.5rem",
      "toolbarBackground": "{semantic.color.surface-default}",
      "toolbarBorder": "{semantic.color.border-default}",
      "viewportBackground": "{semantic.color.background-subtle}",
      "deviceMobile": "375px",
      "deviceDesktop": "100%",
      "frameShadow": "{semantic.shadow.elevated}",
      "frameRadius": "{semantic.radius.panel}"
    },
    "aiAssistantPanel": {
      "width": "26rem",
      "maxWidth": "100vw",
      "background": "{semantic.color.surface-default}",
      "border": "{semantic.color.border-default}",
      "shadow": "{semantic.shadow.elevated}",
      "radius": "{semantic.radius.panel}",
      "header": {
        "background": "{semantic.color.background-subtle}",
        "border": "{semantic.color.border-default}"
      },
      "messageUser": {
        "background": "{semantic.color.interactive-default}",
        "text": "{semantic.color.text-inverse}"
      },
      "messageAssistant": {
        "background": "{semantic.color.background-subtle}",
        "text": "{semantic.color.text-primary}"
      },
      "diffAdded": {
        "background": "{global.color.success-100}",
        "text": "{global.color.success-700}"
      },
      "diffRemoved": {
        "background": "{global.color.danger-100}",
        "text": "{global.color.danger-700}"
      },
      "inputArea": {
        "background": "{semantic.color.surface-default}",
