# Public environment variables for the Next.js frontend.
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_UNLEASH_APP_NAME=elite-frontend
NEXT_PUBLIC_UNLEASH_PROXY_URL=http://localhost:4242/api/frontend
NEXT_PUBLIC_ENABLED_FEATURES=

# Clerk frontend configuration (required for /admin login and sign-up).
# Get these from your Clerk dashboard: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Optional: endpoint to which Web Vitals are reported.
NEXT_PUBLIC_VITALS_ENDPOINT=/api/vitals

# Vercel Edge Config connection string for canary traffic splitting.
# When `canary.apiUrl` is set, the edge middleware pins canary users with an
# `elite-canary-api-url` cookie so API calls are routed to the backend canary.
# EDGE_CONFIG=edge-config://<edge-config-id>
