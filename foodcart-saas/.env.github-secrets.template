# GitHub Actions secrets for Foodcart SaaS
# Copy this file to .env.github-secrets, fill in the values, and run:
#   VERCEL_TOKEN=<token> ./scripts/set-github-secrets.sh
#
# Do NOT commit .env.github-secrets.

# Database connection strings (PostgreSQL)
STAGING_DATABASE_URL=postgresql+psycopg://user:pass@host:5432/foodcart_staging
PRODUCTION_DATABASE_URL=postgresql+psycopg://user:pass@host:5432/foodcart_production

# Clerk authentication
CLERK_JWKS_URL=https://your-domain.clerk.accounts.dev/.well-known/jwks.json
CLERK_AUDIENCE=
CLERK_ISSUER=https://your-domain.clerk.accounts.dev

# AI assistant (Google Gemini)
GEMINI_API_KEY=your-gemini-api-key

# CI / test
CI_SECRET_KEY=change-me-in-ci

# Redis (optional; required for multi-process rate limiting)
REDIS_URL=

# Feature flags (optional)
UNLEASH_API_TOKEN=
MANAGED_FEATURE_FLAGS_TOKEN=

# Canary routing
VERCEL_EDGE_CONFIG_ID=

# Observability (optional)
OTEL_EXPORTER_OTLP_HEADERS=
